## Backend environment variables (copy to `.env`)
#
# IMPORTANT: Do not commit your real `.env` file.

# Flask / JWT
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=smreport_db

# Google Gemini
GEMINI_API_KEY=your-google-api-key-here

# Server
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000
